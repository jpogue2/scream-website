---
// src/components/AppFooter.astro
// Compact two-column footer: logo/description left, socials+copyright right.
// Nonintrusive: keeps element sizes but tightens spacing to reduce vertical height.
---
<footer class="bg-white text-gray-700 border-t border-gray-100">
  <div class="container mx-auto px-6 py-8"> <!-- reduced vertical padding -->

    <div class="flex flex-col md:flex-row justify-between items-start gap-8"> <!-- smaller gap -->

      <!-- LEFT SIDE -->
      <div class="max-w-md space-y-3"> <!-- tighter vertical spacing -->
        <!-- Logo -->
        <a href="/" class="inline-flex items-center">
          <img src="/images/logo.png" alt="Scream USC logo" class="h-12 w-auto" />
        </a>

        <!-- Description: slightly tighter leading to save vertical space -->
        <p class="text-sm text-gray-600 leading-snug">
          USC's student organization for themed entertainment enthusiasts and ride engineers.
        </p>
      </div>

      <!-- RIGHT SIDE -->
      <div class="flex flex-col items-start md:items-end gap-3">

        <!-- Social Icons -->
        <div class="flex items-center gap-4">

          <!-- Instagram -->
          <a href="https://www.instagram.com/screamusc/" target="_blank" aria-label="Instagram"
            class="hover:scale-110 transition transform">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 hover:text-[var(--color-primary,#ff9248)] transition"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/scream-usc/" target="_blank" aria-label="LinkedIn"
            class="hover:scale-110 transition transform">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 hover:text-[var(--color-primary,#ff9248)] transition"
                viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.94 6.5A1.94 1.94 0 1 1 3 6.5a1.94 1.94 0 0 1 3.94 0zM4 8.75h4v11H4zM10 8.75h3.8v1.5h.05c.53-.95 1.82-1.95 3.75-1.95 4.01 0 4.75 2.64 4.75 6.07v6.38h-4v-5.66c0-1.35-.03-3.09-1.88-3.09-1.88 0-2.17 1.47-2.17 3v5.75h-4z"/>
            </svg>
          </a>

          <!-- Linktree -->
          <a href="https://linktr.ee/screamusc?utm_source=linktree_profile_share&ltsid=10217ce8-c5de-498c-9019-163adb011965" target="_blank" aria-label="Linktree"
            class="hover:scale-110 transition transform">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 hover:text-[var(--color-primary,#ff9248)] transition"
                viewBox="0 0 24 24" fill="currentColor">
              <path d="M11 2h2v4h3l-4 4-4-4h3V2zm-4 8h10v2H7v-2zm4 3h2v9h-2v-9z"/>
            </svg>
          </a>

          <!-- Email -->
          <a href="mailto:screamusc@gmail.com" aria-label="Email"
            class="hover:scale-110 transition transform">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 hover:text-[var(--color-primary,#ff9248)] transition"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
          </a>

        </div>

        <!-- Copyright -->
        <p class="text-xs text-gray-500">
          © {new Date().getFullYear()} Scream USC
        </p>

      </div>

    </div>

  </div>
</footer>