---
// src/components/ClubCarousel.astro
// Copy-and-paste this file into your project (replaces your existing ClubCarousel.astro).
// Improvements included:
// - Preloads neighbor images via <link rel="preload"> and Image() warm-up
// - Sets the visible slide to loading="eager" and fetchpriority="high" (toggled in JS)
// - Adds width/height / aspect-ratio placeholders to avoid layout shift
// - Optional `preloadAhead` prop to warm more than just immediate neighbors
// - Keeps all original accessibility / keyboard / touch behavior
//
// Props:
// - images: string[] (image URLs)
// - interval: number (ms between auto-advance)
// - preloadAhead: number (how many slides ahead/behind to warm; default 1)
import Container from "./Container.astro";

const {
  images = [],
  interval = 6000,
  preloadAhead = 1
} = Astro.props;
---
<style>
  /* Small local helpers (non-invasive) */
  .carousel-track { transition: transform .7s ease; will-change: transform; }
  .carousel-dot { width:10px; height:10px; border-radius:9999px; opacity:.45; }
  .carousel-dot.active { opacity:1; transform:scale(1.05); }
  /* simple blurred placeholder fallback for perceived performance */
  .img-wrapper {
    background: linear-gradient(90deg, #f3f4f6 0%, #e5e7eb 50%, #f3f4f6 100%);
  }
</style>

<Container>
  <div data-component="club-carousel" data-interval={interval} data-preloadahead={preloadAhead} class="relative z-0 mt-6 md:mt-8" aria-roledescription="carousel">
    <div class="carousel overflow-hidden">
      <div class="carousel-track flex" role="list">
        {images.map((src, i) => (
          <div class="carousel-slide flex-shrink-0 w-full" role="listitem" aria-hidden={i !== 0}>
            <!-- Fixed-height wrapper that crops vertically. Adjust heights below to taste. -->
            <div class="w-full h-56 md:h-[420px] lg:h-[560px] overflow-hidden img-wrapper">
              <!--
                Notes:
                - width/height are suggested intrinsic sizes to reduce layout shifts.
                - We default images to loading="lazy" and switch the visible slide to eager in JS.
                - fetchpriority is toggled in JS; browsers that support it will honor it.
                - Keep alt text meaningful if you have it (here left blank for decorative).
              -->
              <img
                src={src}
                alt=""
                class="w-full h-full object-cover object-center"
                loading="lazy"
                decoding="async"
                width="1600"
                height="900"
                style="aspect-ratio:16/9"
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Prev / Next controls -->
      <button
        class="absolute left-3 top-1/2 -translate-y-1/2 z-20 rounded-full bg-primary text-white p-2 shadow-lg hover:scale-105 active:scale-95 transition"
        aria-label="Previous slide"
        data-action="prev"
      >
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 15L7 10L12 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <button
        class="absolute right-3 top-1/2 -translate-y-1/2 z-20 rounded-full bg-primary text-white p-2 shadow-lg hover:scale-105 active:scale-95 transition"
        aria-label="Next slide"
        data-action="next"
      >
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 5L13 10L8 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <!-- dots -->
      <div class="absolute left-1/2 bottom-4 -translate-x-1/2 z-20 flex gap-3">
        {images.map((_, i) => (
          <button class="carousel-dot bg-primary/50" aria-label={`Go to slide ${i + 1}`} data-index={i}></button>
        ))}
      </div>
    </div>
  </div>
</Container>

<script>
  (function () {
    const wrapper = document.querySelector('[data-component="club-carousel"]');
    if (!wrapper) return;
    const carousel = wrapper.querySelector('.carousel');
    const track = carousel && carousel.querySelector('.carousel-track');
    const slides = carousel ? Array.from(carousel.querySelectorAll('.carousel-slide')) : [];
    const images = slides.map(s => s.querySelector('img'));
    const dots = carousel ? Array.from(carousel.querySelectorAll('.carousel-dot')) : [];
    const btnPrev = carousel && carousel.querySelector('[data-action="prev"]');
    const btnNext = carousel && carousel.querySelector('[data-action="next"]');
    const INTERVAL = Number(wrapper.dataset.interval) || 6000;
    const PRELOAD_AHEAD = Math.max(1, Number(wrapper.dataset.preloadahead) || 1);

    if (!track || slides.length === 0) return;

    let idx = 0;
    let timer = null;
    const count = slides.length;

    function update() {
      track.style.transform = `translateX(-${idx * 100}%)`;
      slides.forEach((s, si) => s.setAttribute('aria-hidden', si !== idx));
      dots.forEach((d, di) => d.classList.toggle('active', di === idx));
      setImagePriorities(idx);
      preloadAround(idx, PRELOAD_AHEAD);
    }

    function show(i) {
      idx = ((i % count) + count) % count;
      update();
    }

    function next() { show(idx + 1); }
    function prev() { show(idx - 1); }

    function start() {
      stop();
      timer = setInterval(next, INTERVAL);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    // Toggle attributes so visible image gets priority
    function setImagePriorities(currentIdx) {
      images.forEach((img, i) => {
        if (!img) return;
        if (i === currentIdx) {
          // visible image: eager + high priority (if supported)
          try { img.loading = 'eager'; } catch (e) {}
          try { img.setAttribute('fetchpriority', 'high'); } catch (e) {}
          img.decoding = 'async';
          // ensure minimal placeholder background is removed when loaded
          if (img.complete) img.closest('.img-wrapper')?.classList.remove('img-wrapper');
        } else {
          try { img.loading = 'lazy'; } catch (e) {}
          try { img.setAttribute('fetchpriority', 'auto'); } catch (e) {}
        }
      });
    }

    // Preload neighbors (and optionally additional slides ahead)
    function preloadAround(currentIdx, ahead = 1) {
      const toPreload = new Set();
      for (let offset = 1; offset <= ahead; offset++) {
        toPreload.add((currentIdx + offset) % count);
        toPreload.add((currentIdx - offset + count) % count);
      }

      toPreload.forEach(i => {
        const img = images[i];
        if (!img) return;
        // If not yet fully loaded, create an Image() to warm the browser cache.
        if (!img.complete) {
          const warm = new Image();
          warm.src = img.src;
          // If you use CORS-enabled images, you could set warm.crossOrigin = 'anonymous';
        }
        // Add a <link rel="preload"> hint if not already present
        const selector = `link[data-preload="${img.src}"]`;
        if (!document.querySelector(selector)) {
          const link = document.createElement('link');
          link.rel = 'preload';
          link.as = 'image';
          link.href = img.src;
          link.setAttribute('data-preload', img.src);
          document.head.appendChild(link);
        }
      });
    }

    // init
    show(0);
    start();

    // dots click
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const i = Number(dot.dataset.index);
        show(i);
        stop();
      });
    });

    if (btnPrev) btnPrev.addEventListener('click', () => { prev(); stop(); });
    if (btnNext) btnNext.addEventListener('click', () => { next(); stop(); });

    // pause on hover/focus
    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
    carousel.addEventListener('focusin', stop);
    carousel.addEventListener('focusout', start);

    // keyboard
    carousel.tabIndex = 0;
    carousel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { next(); stop(); }
      if (e.key === 'ArrowLeft') { prev(); stop(); }
    });

    // basic touch swipe
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; stop(); }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].screenX;
      const dx = touchEndX - touchStartX;
      if (Math.abs(dx) > 40) { if (dx < 0) next(); else prev(); }
      start();
    }, { passive: true });

    // HMR cleanup (Vite)
    if (import.meta.hot) {
      import.meta.hot.dispose(() => {
        stop();
      });
    }
  })();
</script>