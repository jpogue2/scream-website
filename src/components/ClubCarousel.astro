---
// ClubCarousel.astro
// Props:
//  - images: string[] (paths to images)
//  - interval: number in ms (rotation interval)
const { images = [], interval = 5000 } = Astro.props;
---
<style>
/* small local styles to keep the carousel predictable */
.carousel-img {
  object-fit: cover;
  width: 100%;
  height: 56vh; /* tall hero; adjust as desired */
  min-height: 340px;
}
@media (min-width: 1024px) {
  .carousel-img { height: 72vh; min-height: 480px; }
}
</style>

<div class="relative overflow-hidden">
  <!-- slides -->
  <div id="club-carousel" class="relative">
    {images.map((src, i) => (
      <picture class={`absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
        <img src={src} alt={`Club slide ${i + 1}`} class="carousel-img w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
      </picture>
    ))}
  </div>

  <!-- centered overlay text -->
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
    <div class="pointer-events-auto text-center px-6">
      <h1 class="text-white text-4xl sm:text-5xl md:text-6xl font-extrabold drop-shadow-lg">Scream USC</h1>
      <p class="mt-3 text-white/90 text-base sm:text-lg md:text-xl drop-shadow-lg max-w-3xl">
        USC's student organization for theme park enthusiasts and engineers.
      </p>
    </div>
  </div>

  <!-- controls / indicators -->
  <div class="absolute left-1/2 bottom-6 -translate-x-1/2 flex gap-2">
    {images.map((_, i) => (
      <button
        type="button"
        class="w-3 h-3 rounded-full bg-white/60 ring-0 focus:outline-none focus:ring-2 focus:ring-white"
        aria-label={`Go to slide ${i + 1}`}
        data-dot={i}
      />
    ))}
  </div>
</div>

<script type="module">
  // Lightweight client-side carousel: no external libs.
  (function () {
    const carousel = document.getElementById('club-carousel');
    if (!carousel) return;

    const slides = Array.from(carousel.querySelectorAll('picture'));
    const dots = Array.from(document.querySelectorAll('[data-dot]'));
    if (!slides.length) return;

    let current = 0;
    let timer = null;
    const intervalMs = Number(Astro.props.interval || 5000);

    function show(idx) {
      slides.forEach((s, i) => s.style.opacity = i === idx ? '1' : '0');
      dots.forEach((d, i) => d.classList.toggle('bg-white', i === idx));
      current = idx;
    }

    function next() { show((current + 1) % slides.length); }

    // attach dot clicks
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const i = Number(dot.dataset.dot);
        show(i);
        reset();
      });
    });

    function reset() {
      if (timer) clearInterval(timer);
      timer = setInterval(next, intervalMs);
    }

    // start
    reset();

    // pause on hover (desktop)
    const wrapper = carousel.parentElement;
    wrapper.addEventListener('mouseenter', () => clearInterval(timer));
    wrapper.addEventListener('mouseleave', reset);

    // initial render
    show(0);
  })();
</script>