---
// src/components/ClubCarousel.astro
// Fix: remove inline button background, make buttons frosted/transparent and reliably centered.
import Container from "./Container.astro";

const {
  images = [],
  interval = 6000,
  preloadAhead = 1,
  saturation = 0.75,
  tintColor = "#ff7a00",
  tintOpacity = 0.05,
  tintBlend = "multiply"
} = Astro.props;
---
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;900&family=Inter:wght@300;400;600&display=swap');

  /* Ensure carousel is the positioning context */
  .carousel { position: relative; }

  /* Track, dots */
  .carousel-track { transition: transform .7s ease; will-change: transform; display: flex; }
  .carousel-dot.active { opacity:1; transform:scale(1.05); }

  /* Placeholder background while image loads */
  .img-wrapper {
    background: linear-gradient(90deg, #f3f4f6 0%, #e5e7eb 50%, #f3f4f6 100%);
    position: relative;
    overflow: hidden;
  }

  /* Images */
  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(var(--carousel-saturation, 1));
    transition: filter 240ms ease, opacity 240ms ease;
    display: block;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* Per-slide tint */
  .tint-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: var(--carousel-tint-blend, multiply);
    transition: opacity 240ms ease;
    z-index: 10;
  }

  .img-loaded { background: transparent !important; }

  /* ===== Controls =====
     Frosted / semi-transparent controls that remain readable and centered.
  */
  .carousel .control-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%); /* reliable vertical centering */
    z-index: 60;                 /* above tint + pills */
    pointer-events: auto;

    width: 44px;
    height: 44px;
    display: inline-grid;
    place-items: center;
    border-radius: 9999px;

    /* frosted look (semi-transparent) */
    background-color: rgba(255,146,72,0.6);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);

    /* isolate from blend effects */
    mix-blend-mode: normal;
    isolation: isolate;

    /* separation */
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: 0 8px 24px rgba(11,17,32,0.16);

    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
  }

  /* Left / right anchors */
  .carousel .control-btn.left  { left: 0.75rem; }
  .carousel .control-btn.right { right: 0.75rem; }

  /* Hover / active */
  .carousel .control-btn:hover {
    transform: translateY(-50%) scale(1.06);
    box-shadow: 0 12px 34px rgba(11,17,32,0.20);
    background-color: rgba(255,255,255,0.10);
  }
  .carousel .control-btn:active {
    transform: translateY(-50%) scale(.98);
  }

  /* Icon (stroke white + tiny shadow so it's visible on bright areas) */
  .control-btn svg {
    width: 18px;
    height: 18px;
    display: block;
    stroke: white;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.35));
  }

  /* Visible pagination dots */
  .carousel .dots {
    position: absolute;
    left: 50%;
    bottom: 1rem;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    gap: 0.6rem;
    pointer-events: auto;
    align-items: center;
  }

  /* base dot (use your primary color, with a subtle outer ring so it reads on any background) */
  .carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background-color: rgba(255,146,72,0.95); /* primary fill */
    border: 2px solid rgba(255,255,255,0.9);  /* thin white ring for contrast on dark areas */
    box-shadow: 0 6px 14px rgba(11,17,32,0.18);
    opacity: 0.95;
    transition: transform .18s ease, opacity .12s ease, box-shadow .18s ease;
    padding: 0;
    margin: 0;
    cursor: pointer;
  }

  /* inactive subtle state */
  .carousel-dot:not(.active) {
    transform: scale(1);
    opacity: 0.68;
    filter: none;
    border-color: rgba(255,255,255,0.8);
    background-color: rgba(255,146,72,0.72);
  }

  /* active / current slide */
  .carousel-dot.active {
    transform: scale(1.28);
    opacity: 1;
    box-shadow: 0 10px 26px rgba(11,17,32,0.22);
    background-color: rgba(255,146,72,1);
    border-color: rgba(255,255,255,1);
  }

  /* keyboard / focus visible */
  .carousel-dot:focus {
    outline: 3px solid rgba(255,146,72,0.18);
    outline-offset: 4px;
  }

  /* ===== Top Hero Overlay (pills) ===== */
  .carousel-hero-overlay {
    position: absolute;
    top: 12%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 45; /* below controls (60) but above tint (10) */
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    pointer-events: none;
    width: 100%;
    padding: 0 1rem;
  }

  /* Pills: keep mix-blend-mode normal and isolate stacking context */
  .carousel-title-pill,
  .carousel-sub-pill {
    display: inline-block;
    border-radius: 9999px;
    background-color: rgba(255,146,72,0.6);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    mix-blend-mode: normal;
    isolation: isolate;
    position: relative;
    z-index: 45;
    pointer-events: none;
    box-shadow: 0 8px 22px rgba(0,0,0,0.28);
  }

  .carousel-title-pill { padding: 0.45rem 1.05rem; }
  .carousel-sub-pill   { margin-top: 0.5rem; padding: 0.32rem 0.9rem; }

  .carousel-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5.2vw, 3.6rem);
    font-weight: 700;
    color: white;
    line-height: 1.05;
    margin: 0;
  }

  .carousel-subtitle {
    font-family: 'Fraunces', serif;
    font-style: italic;
    margin: 0;
    font-size: clamp(0.95rem, 1.9vw, 1.2rem);
    font-weight: 500;
    color: white;
    line-height: 1.15;
  }

  @media (max-width: 420px) {
    .carousel-title { font-size: 1.6rem; }
  }
</style>

<Container>
  <div
    data-component="club-carousel"
    data-interval={interval}
    data-preloadahead={preloadAhead}
    class="relative z-0 mt-6 md:mt-8"
    aria-roledescription="carousel"
  >
    <div class="carousel overflow-hidden">
      <div class="carousel-track" role="list">
        {images.map((src, i) => (
          <div class="carousel-slide flex-shrink-0 w-full" role="listitem" aria-hidden={i !== 0}>
            <div
              class="w-full h-56 md:h-[420px] lg:h-[560px] overflow-hidden img-wrapper"
              style={`--carousel-saturation:${saturation}; --carousel-tint-blend:${tintBlend};`}
            >
              <img
                src={src}
                alt=""
                class="w-full h-full object-cover object-center"
                loading="lazy"
                decoding="async"
                width="1600"
                height="900"
                style="aspect-ratio:16/9"
              />
              <div
                aria-hidden="true"
                class="tint-overlay"
                style={`background: ${tintColor}; opacity: ${tintOpacity};`}
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Top-middle Text Overlay with pill highlights -->
      <div class="carousel-hero-overlay" aria-hidden="true">
        <span class="carousel-title-pill">
          <h1 class="carousel-title">Scream USC</h1>
        </span>

        <span class="carousel-sub-pill">
          <p class="carousel-subtitle">Themed entertainment enthusiasts and engineers</p>
        </span>
      </div>

      <!-- Prev / Next controls: NO inline background styles so CSS can make them frosted -->
      <button
        class="control-btn left"
        aria-label="Previous slide"
        data-action="prev"
        type="button"
      >
        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M12 15L7 10L12 5" /></svg>
      </button>

      <button
        class="control-btn right"
        aria-label="Next slide"
        data-action="next"
        type="button"
      >
        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M8 5L13 10L8 15" /></svg>
      </button>

      <!-- dots -->
      <div class="dots" role="tablist" aria-label="Slide dots">
        {images.map((_, i) => (
          <button class="carousel-dot" aria-label={`Go to slide ${i + 1}`} data-index={i}></button>
        ))}
      </div>
    </div>
  </div>
</Container>

<script>
  (function () {
    const wrapper = document.querySelector('[data-component="club-carousel"]');
    if (!wrapper) return;
    const carousel = wrapper.querySelector('.carousel');
    const track = carousel && carousel.querySelector('.carousel-track');
    const slides = carousel ? Array.from(carousel.querySelectorAll('.carousel-slide')) : [];
    const images = slides.map(s => s.querySelector('img'));
    const dots = carousel ? Array.from(carousel.querySelectorAll('.carousel-dot')) : [];
    const btnPrev = carousel && carousel.querySelector('[data-action="prev"]');
    const btnNext = carousel && carousel.querySelector('[data-action="next"]');
    const INTERVAL = Number(wrapper.dataset.interval) || 6000;
    const PRELOAD_AHEAD = Math.max(1, Number(wrapper.dataset.preloadahead) || 1);

    if (!track || slides.length === 0) return;

    let idx = 0;
    let timer = null;
    const count = slides.length;

    function update() {
      track.style.transform = `translateX(-${idx * 100}%)`;
      slides.forEach((s, si) => s.setAttribute('aria-hidden', si !== idx));
      dots.forEach((d, di) => d.classList.toggle('active', di === idx));
      setImagePriorities(idx);
      preloadAround(idx, PRELOAD_AHEAD);
    }

    function show(i) {
      idx = ((i % count) + count) % count;
      update();
    }

    function next() { show(idx + 1); }
    function prev() { show(idx - 1); }

    function start() {
      stop();
      timer = setInterval(next, INTERVAL);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    // Toggle attributes so visible image gets priority
    function setImagePriorities(currentIdx) {
      images.forEach((img, i) => {
        if (!img) return;
        const wrapperEl = img.closest('.img-wrapper');
        if (i === currentIdx) {
          try { img.loading = 'eager'; } catch (e) {}
          try { img.setAttribute('fetchpriority', 'high'); } catch (e) {}
          img.decoding = 'async';
          if (img.complete) wrapperEl?.classList.add('img-loaded');
        } else {
          try { img.loading = 'lazy'; } catch (e) {}
          try { img.setAttribute('fetchpriority', 'auto'); } catch (e) {}
        }
      });
    }

    // Preload neighbors (and optionally additional slides ahead)
    function preloadAround(currentIdx, ahead = 1) {
      const toPreload = new Set();
      for (let offset = 1; offset <= ahead; offset++) {
        toPreload.add((currentIdx + offset) % count);
        toPreload.add((currentIdx - offset + count) % count);
      }

      toPreload.forEach(i => {
        const img = images[i];
        if (!img) return;
        if (!img.complete) {
          const warm = new Image();
          warm.src = img.src;
        }
        const selector = `link[data-preload="${img.src}"]`;
        if (!document.querySelector(selector)) {
          const link = document.createElement('link');
          link.rel = 'preload';
          link.as = 'image';
          link.href = img.src;
          link.setAttribute('data-preload', img.src);
          document.head.appendChild(link);
        }
      });
    }

    // When an image finishes loading, remove placeholder background for smoother look
    images.forEach((img) => {
      if (!img) return;
      img.addEventListener('load', (e) => {
        const wrapperEl = img.closest('.img-wrapper');
        if (wrapperEl) wrapperEl.classList.add('img-loaded');
      });
    });

    // init
    show(0);
    start();

    // dots click
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const i = Number(dot.dataset.index);
        show(i);
        stop();
      });
    });

    if (btnPrev) btnPrev.addEventListener('click', () => { prev(); stop(); });
    if (btnNext) btnNext.addEventListener('click', () => { next(); stop(); });

    // pause on hover/focus
    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
    carousel.addEventListener('focusin', stop);
    carousel.addEventListener('focusout', start);

    // keyboard
    carousel.tabIndex = 0;
    carousel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { next(); stop(); }
      if (e.key === 'ArrowLeft') { prev(); stop(); }
    });

    // touch support (swipe)
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; stop(); }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].screenX;
      const dx = touchEndX - touchStartX;
      if (Math.abs(dx) > 40) { if (dx < 0) next(); else prev(); }
      start();
    }, { passive: true });

    // HMR cleanup
    if (import.meta.hot) {
      import.meta.hot.dispose(() => {
        stop();
      });
    }
  })();
</script>