---
// src/components/Header.astro
import Container from "./Container.astro";
const links = [
  { to: "/",        label: "Home" },
  { to: "/people",  label: "People" },
  { to: "/members", label: "Members Only" },
  { to: "/join",    label: "Join" },
];
---
<header>
  <nav id="nav" class="relative group z-10 w-full border-b border-black/5 lg:border-transparent">
    <Container>
      <div class="relative flex flex-wrap items-center justify-between gap-6 py-3 md:gap-0 md:py-4">

        <!-- LOGO + HAMBURGER -->
        <div class="relative z-20 flex w-full justify-between md:px-0 lg:w-fit">
          <a href="/" class="flex items-center">
            <img src="/images/logo.png" alt="Scream USC Logo" class="h-20 w-auto" />
          </a>

          <div class="relative flex max-h-10 items-center lg:hidden">
            <button aria-label="hamburger" id="hamburger" class="relative -mr-6 p-6 active:scale-95 duration-300">
              <div aria-hidden="true"
                class="m-auto h-0.5 w-5 rounded bg-gray-950 transition duration-300 origin-top group-data-[state=active]:rotate-45 group-data-[state=active]:translate-y-1.5">
              </div>
              <div aria-hidden="true"
                class="m-auto mt-2 h-0.5 w-5 rounded bg-gray-950 transition duration-300 origin-bottom group-data-[state=active]:-rotate-45 group-data-[state=active]:-translate-y-1">
              </div>
            </button>
          </div>
        </div>

        <!-- Mobile overlay -->
        <div id="navLayer"
          aria-hidden="true"
          class="fixed inset-0 z-10 h-screen w-screen origin-bottom scale-y-0 bg-white/70 backdrop-blur-2xl transition duration-500 group-data-[state=active]:origin-top group-data-[state=active]:scale-y-100 lg:hidden">
        </div>

        <!-- Nav Links -->
        <div id="navlinks"
          class="invisible absolute top-full left-0 z-20 w-full origin-top-right translate-y-1 scale-90 flex-col flex-wrap justify-end gap-6 rounded-3xl border border-gray-100 bg-white p-8 opacity-0 shadow-2xl shadow-gray-600/10 transition-all duration-300 lg:visible lg:relative lg:flex lg:w-fit lg:translate-y-0 lg:scale-100 lg:flex-row lg:items-center lg:gap-0 lg:border-none lg:bg-transparent lg:p-0 lg:opacity-100 lg:shadow-none group-data-[state=active]:visible group-data-[state=active]:scale-100 group-data-[state=active]:opacity-100 lg:group-data-[state=active]:translate-y-0">

          <div class="w-full text-gray-600 lg:w-auto lg:pr-4 lg:pt-0">
            <div id="links-group" class="flex items-center flex-col gap-6 tracking-wide lg:flex-row lg:gap-0 lg:text-sm">

              {
                links.map((link) => (
                  link.to === "/join" ? (
                    <a
                      href={link.to}
                      class="relative flex h-9 items-center justify-center px-4 rounded-full text-sm font-semibold transition-transform duration-150 focus:outline-none"
                      style="
                        background: linear-gradient(180deg, var(--color-primary, #ff9c58), var(--color-primary, #ff9248));
                        color: white;
                        box-shadow: 0 8px 22px rgba(255,146,72,0.22);
                        -webkit-tap-highlight-color: transparent;
                      "
                    >
                      <span class="relative select-none">{link.label}</span>
                      <span class="absolute -inset-px rounded-full ring-offset-2 pointer-events-none"></span>
                    </a>
                  ) : (
                    <a href={link.to} class="flex items-center h-9 hover:text-primary transition md:px-4">
                      <span class="text-sm">{link.label}</span>
                    </a>
                  )
                ))
              }

            </div>
          </div>

        </div>
      </div>
    </Container>
  </nav>
</header>

<script>
  let isToggled = false;
  const navbar = document.querySelector("#nav");
  const menuBtn = document.querySelector("#hamburger");
  const navLinks = [...navbar.querySelector("#links-group").children];

  function toggleNavlinks() {
    navbar.dataset.state = isToggled ? "active" : "";
  }

  if (menuBtn) {
    menuBtn.addEventListener("click", () => {
      isToggled = !isToggled;
      toggleNavlinks();
    });
  }

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      isToggled = false;
      toggleNavlinks();
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && navbar.dataset.state === "active") {
      isToggled = false;
      toggleNavlinks();
    }
  });
</script>