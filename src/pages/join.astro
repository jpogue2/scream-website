---
import Layout from '../layouts/Layout.astro';
const MAILING_LIST_URL = 'http://eepurl.com/iinhb5'; // <-- replace with your Google Form / Linktree / Typeform URL
const INSTAGRAM_URL = 'https://www.instagram.com/screamusc/'; // <-- replace with your Instagram
const CONTACT_EMAIL = 'screamusc@gmail.com'; // <-- replace with your contact email
const REC_EMAIL = 'jpogue@usc.edu'; // <-- replace with your contact email
---

<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;900&display=swap');

.page-h2 {
  font-family: 'Fraunces', Georgia, serif;
  font-weight: 700;
  font-size: clamp(2rem, 3.75vw, 3rem);
  line-height: 1.02;
  margin: 0;
  text-align: center;
  padding-bottom: 0.6rem;
  position: relative;
  display: block;
}

.page-h2 .title-inner {
  display: inline-block;
  position: relative;
  padding-bottom: 0.25rem;
}

.page-h2 .title-inner::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -0.18rem;
  height: 0.48rem;
  border-radius: 999px;
  background: linear-gradient(
    90deg,
    var(--color-primary),
    var(--color-primary)
  );
  z-index: -1;
  opacity: 0.95;
}

/* Reusable CTA pill */
.cta-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.7rem 1.1rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 1rem;
  color: #fff;
  background: linear-gradient(180deg, var(--color-primary), var(--color-primary));
  box-shadow: 0 10px 24px rgba(255,146,72,0.12);
  text-decoration: none;
}
.cta-pill:focus { outline: 3px solid rgba(255,146,72,0.12); outline-offset: 3px; }
.icon {
  width: 1.2rem;
  height: 1.2rem;
  flex: 0 0 1.2rem;
}

/* Subtle card for whole area (optional visual grouping) */
.join-card {
  background: var(--color-secondary);
  border-radius: 1rem;
  padding: 2rem;
  box-shadow: 0 8px 24px rgba(11,17,32,0.04);
}

/* Link styles for secondary actions */
.secondary-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.56rem 1rem;
  border-radius: 999px;
  font-weight: 600;
  font-size: 0.95rem;
  color: #0b1220;
  background: white;
  border: 1px solid rgba(11,17,32,0.04);
  text-decoration: none;
  box-shadow: 0 6px 18px rgba(11,17,32,0.04);
}
.secondary-cta:hover { transform: translateY(-2px); transition: transform 140ms ease; }
</style>

<Layout title="Join | Scream USC">
  <main class="container mx-auto px-6 py-16">
    <div class="max-w-3xl mx-auto">

      <!-- Title -->
      <h1 class="page-h2 mb-16">
        <span class="title-inner">Join Scream USC</span>
      </h1>

      <!-- Short intro + mailing list CTA -->
      <section class="join-card text-center mt-16 mb-12">
        <p class="text-lg text-gray-800 max-w-2xl mx-auto">
          Interested? Scream USC is open to all USC students, regardless of year or major! Sign up for our mailing list below to get event announcements.
        </p>

        <div class="mt-8">
          <a
            class="cta-pill"
            href={MAILING_LIST_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Sign up for the Scream USC mailing list (opens a new tab)"
          >
            <!-- Simple mail icon (list) -->
            <svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 7.5a2 2 0 012-2h14a2 2 0 012 2v.5l-9 5.5-9-5.5V7.5z" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 10.5v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Join the mailing list
          </a>
        </div>
      </section>

      <!-- Contact options -->
      <section class="text-center mb-6">
        <p class="text-gray-700 text-base">
          Also, feel free to reach out to us on any of our channels:
        </p>

        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
          <!-- Instagram -->
          <a
            class="secondary-cta"
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open Scream USC Instagram (opens a new tab)"
          >
            <!-- Instagram logo (simple) -->
            <svg class="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
              <path d="M17.5 6.5h.01" stroke-linecap="round"/>
            </svg>
            <span>Instagram</span>
          </a>

          <!-- Email -->
          <a
            class="secondary-cta"
            href={`mailto:${CONTACT_EMAIL}`}
            aria-label="Email Scream USC"
          >
            <!-- Mail icon -->
            <svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 7.5a2 2 0 012-2h14a2 2 0 012 2v.5l-9 5.5-9-5.5V7.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 10.5v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>General Email</span>
          </a>

          <!-- REC Contact -->
          <a
            class="secondary-cta"
            href={`mailto:${REC_EMAIL}`}
            aria-label="Email Scream USC"
          >
            <!-- Wrench icon -->
            <svg
              class="icon"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M14.7 6.3a4 4 0 01-5.4 5.4l-4.8 4.8a1.5 1.5 0 102.1 2.1l4.8-4.8a4 4 0 005.4-5.4l-2.2 2.2a1 1 0 01-1.4 0l-1.2-1.2a1 1 0 010-1.4l2.2-2.2z"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>Ride Engineering Competition Email</span>
          </a>
        </div>
      </section>

    </div>
  </main>
</Layout>