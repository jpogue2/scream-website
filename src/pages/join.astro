---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join | Scream USC">
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <h1 class="text-4xl font-bold text-white mb-4">
        Under Construction
      </h1>

      <p class="text-lg text-neutral-400">
        The Join page is currently being built.  
        Please check back soon.
      </p>

      <a href="/" class="inline-block mt-8 text-red-500 hover:text-red-400 transition font-medium">
        ← Back to Home
      </a>
    </div>
  </main>
</Layout>