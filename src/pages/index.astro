---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ClubCarousel from '../components/ClubCarousel.astro';
import AboutSection from '../components/AboutSection.astro';
import AlumniCollage from '../components/AlumniCollage.astro';

const carouselImages = [
  '/images/scream-usc/scream-usc-mcn.jpeg',
  '/images/scream-usc/scream-usc-iaapa.jpeg',
  '/images/scream-usc/scream-usc-dreamlab.jpeg',
  '/images/scream-usc/scream-usc-meow-wolf.jpeg',
  '/images/scream-usc/scream-usc-universal.jpeg',
  '/images/scream-usc/scream-usc-workshop.jpeg',
];

const alumniLogos = [
  '/images/clients/wdi.svg',
  '/images/clients/universal.svg',
  '/images/clients/knotts.svg',
];

const features = [
  { title: 'Love Theme Parks?', body: 'Join us for exclusive park trips with discounted tickets, extra ride time, and behind-the-scenes access you won\'t get on your own.' },
  { title: 'Interested in the Industry?', body: 'Meet professionals, attend conferences/fairs, tour working facilities, and compete in the Ride Engineering Competition to build real experience.' },
];
---
<Layout title="Scream USC — Home">
  <main>
    <ClubCarousel images={carouselImages} interval={6000} />

    <!-- All about / features / alumni are rendered by AboutSection -->
    <AboutSection title="Who We Are" lead="Scream USC is USC's student organization for theme park enthusiasts and engineers. We run park trips around the Los Angeles region, behind-the-scenes tours, guest speaker talks with industry professionals, and participate in the Ride Engineering Competition. Membership is open to all majors and years — come build, learn, and ride with us." features={features} alumniLogos={alumniLogos} />

  </main>
</Layout>