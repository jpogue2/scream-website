---
import Layout from '../layouts/Layout.astro';

const members = [
  { img: '/images/people/ava.jpg', name: 'Ava Lorelei Deakin', role: 'President', email: 'ldeakin@usc.edu' },
  { img: '/images/people/angelina.jpg', name: 'Angelina Rocchio', role: 'Vice President', email: 'arocchio@usc.edu' },
  { img: '/images/people/evan.jpg', name: 'Evan Gee', role: 'Director of Marketing', email: 'evangee@usc.edu' },
  { img: '/images/people/amandine.jpg', name: 'Amandine Kataoka', role: 'Directory of Outreach', email: 'akataoka@usc.edu' },
  { img: '/images/people/charlie.jpg', name: 'Charlie Blumling', role: 'Director of Events', email: 'blumling@usc.edu' },
  { img: '/images/people/jeremy.jpeg', name: 'Jeremy Pogue', role: 'Director of Industry', email: 'jpogue@usc.edu' },
  { img: '/images/people/aiden.jpg', name: 'Aiden Lim', role: 'Director of Project Oversight', email: 'aidenlim@usc.edu' },
  { img: '/images/people/sydney.jpg', name: 'Sydney Heinl', role: 'Director of Project Oversight', email: 'heinl@usc.edu' },
];
---

<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;900&display=swap');

.page-h2 {
  font-family: 'Fraunces', Georgia, serif;
  font-weight: 700;
  font-size: clamp(2rem, 3.75vw, 3rem);
  line-height: 1.02;
  margin: 0;
  text-align: center;
  padding-bottom: 0.6rem;
  position: relative;
  display: block;
}

.page-h2 .title-inner {
  display: inline-block;
  position: relative;
  padding-bottom: 0.25rem;
}

.page-h2 .title-inner::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -0.18rem;
  height: 0.48rem;
  border-radius: 999px;
  background: linear-gradient(
    90deg,
    var(--color-primary),
    var(--color-primary)
  );
  z-index: -1;
  opacity: 0.95;
}
</style>

<Layout title="Meet the 2025-26 Executive Board | Scream USC">
  <main class="container mx-auto px-6 py-16">

    <!-- Title -->
    <h1 class="page-h2 mb-16">
      <span class="title-inner">
        Meet the 2025-26 Executive Board
      </span>
    </h1>

    <!-- Grid -->
    <section class="max-w-6xl mx-auto mt-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        {members.map((m) => (
          <article class="flex flex-col items-center text-center bg-[var(--color-primary)] rounded-2xl p-6 shadow-md">
            
            <img
              src={m.img}
              alt={`Photo of ${m.name}`}
              class="w-28 h-28 md:w-32 md:h-32 rounded-full object-cover mb-4 border-4 border-white"
              loading="lazy"
            />

            <h3 class="text-lg font-semibold text-white">
              {m.name}
            </h3>

            <p class="text-sm text-white/90 mt-1">
              {m.role}
            </p>

            <a 
              class="mt-3 text-sm text-white underline hover:opacity-80 break-all"
              href={`mailto:${m.email}`}
            >
              {m.email}
            </a>

          </article>
        ))}
      </div>
    </section>

    <!-- Bottom Text -->
    <div class="text-center mt-20">
      <p class="text-[var(--color-primary)] text-lg">
        Feel free to reach out to any of us to learn more!
      </p>
    </div>

  </main>
</Layout>