---
import Layout from '../layouts/Layout.astro';
---

<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;900&display=swap');

.page-h2 {
  font-family: 'Fraunces', Georgia, serif;
  font-weight: 700;
  font-size: clamp(2rem, 3.5vw, 2.75rem);
  line-height: 1.05;
  text-align: center;
  position: relative;
  display: block;
}

.page-h2 .title-inner {
  display: inline-block;
  position: relative;
  padding-bottom: 0.25rem;
}

.page-h2 .title-inner::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -0.18rem;
  height: 0.45rem;
  border-radius: 999px;
  background: var(--color-primary);
  z-index: -1;
  opacity: 0.95;
}
</style>

<Layout title="Members-Only | Scream USC">
  <main class="min-h-[70vh] flex items-center justify-center px-6">

    <div class="max-w-xl w-full text-center bg-[var(--color-secondary)] rounded-2xl p-12 shadow-lg">

      <!-- Title -->
      <h1 class="page-h2 text-[var(--color-primary)] mb-6">
        <span class="title-inner">
          Members-Only
        </span>
      </h1>

      <!-- Description -->
      <p class="text-gray-700 text-lg leading-relaxed max-w-md mx-auto">
        This section of the website is restricted to active Scream USC members.
        Access will be available soon.
      </p>

      <!-- Button -->
      <div class="mt-10">
        <a 
          href="/join"
          class="inline-block px-6 py-3 rounded-full font-semibold text-white bg-[var(--color-primary)] hover:opacity-90 transition"
        >
          Interested in Joining?
        </a>
      </div>

    </div>

  </main>
</Layout>