---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Members Only | Scream USC">
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="max-w-xl w-full text-center bg-neutral-900 border border-neutral-800 rounded-2xl p-12 shadow-xl">
      
      <!-- Lock Icon -->
      <div class="mb-6 flex justify-center">
        <div class="w-16 h-16 rounded-full bg-red-600/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" 
               class="h-8 w-8 text-red-500" 
               fill="none" 
               viewBox="0 0 24 24" 
               stroke="currentColor" 
               stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" 
              d="M16.5 10.5V7a4.5 4.5 0 10-9 0v3.5M5.25 10.5h13.5A2.25 2.25 0 0121 12.75v6A2.25 2.25 0 0118.75 21H5.25A2.25 2.25 0 013 18.75v-6A2.25 2.25 0 015.25 10.5z" />
          </svg>
        </div>
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">
        Members Only
      </h1>

      <!-- Subtitle -->
      <p class="text-neutral-400 text-lg leading-relaxed">
        This section of the website is restricted to active Scream USC members.
        Access will be available soon.
      </p>

      <!-- Optional Button -->
      <div class="mt-8">
        <a href="/join" 
           class="inline-block px-6 py-3 rounded-lg bg-red-600 hover:bg-red-500 transition text-white font-medium">
          Interested in Joining?
        </a>
      </div>

    </div>
  </main>
</Layout>