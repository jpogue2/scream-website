---
import { AstroFont } from 'astro-font';
import AppFooter from "../components/AppFooter.astro";
import AppHeader from "../components/AppHeader.astro";
import "./../tailus.css";

const {
  title = "Scream USC",
  description = "Scream USC — USC's student organization for themed entertainment and ride engineering. Park trips, guest speakers, behind-the-scenes tours, and the Ride Engineering Competition.",
  canonical = "https://screamusc.com"
} = Astro.props;

const siteUrl = canonical.replace(/\/$/, '');
const pathname = typeof Astro.request !== 'undefined'
  ? Astro.request.url.replace(Astro.request.origin || '', '') // safe fallback if origin exists
  : '/';
const pageUrl = siteUrl + pathname;
const pageTitle = title && title !== "Scream USC" ? `${title} | Scream USC` : "Scream USC";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Scream USC" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`${siteUrl}/images/social-preview.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/social-preview.jpg`} />

    <!-- Fallback theme color -->
    <meta name="theme-color" content="#0f172a" />

    <!-- JSON-LD Organization Schema -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Scream USC",
        "url": siteUrl,
        "logo": `${siteUrl}/images/logo.png`,
        "sameAs": [
          "https://www.instagram.com/YOUR_HANDLE",
          "https://www.linkedin.com/company/YOUR_PAGE",
          "https://linktr.ee/YOUR_LINKTREE"
        ]
      })}
    </script>

    <!-- Fonts -->
    <AstroFont
      config={[
        {
          name: "Plus Jakarta Sans",
          preload: true,
          display: "swap",
          selector: "html",
          fallback: "sans-serif",
          googleFontsURL:
            "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap",
          src: []
        }
      ]}
    />
  </head>

  <body class="bg-white text-gray-800 dark:bg-gray-950 dark:text-gray-100 text-lg">
    <AppHeader />
    <main class="min-h-[60vh]">
      <slot />
    </main>
    <AppFooter />
  </body>
</html>